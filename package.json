{
  "name": "purplepatch-offline-ai-transcriber",
  "version": "0.2.2",
  "description": "Purplepatch Offline AI Transcriber — professional offline transcription desktop app for macOS and Windows",
  "main": "out/main/index.js",
  "author": "Purplepatch",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "bundle:python:mac": "node scripts/bundle-python.mjs mac",
    "bundle:python:win": "node scripts/bundle-python.mjs win",
    "bundle:python": "node scripts/bundle-python.mjs all",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run dist:mac && npm run dist:win",
    "dist:mac": "npm run bundle:python:mac && npm run build && electron-builder --mac --arm64",
    "dist:win": "npm run bundle:python:win && npm run build && electron-builder --win --x64",
    "dist:publish:mac": "npm run bundle:python:mac && npm run build && electron-builder --mac --arm64 --publish always",
    "dist:publish:win": "npm run bundle:python:win && npm run build && electron-builder --win --x64 --publish always",
    "backend:setup": "cd backend && python3 -m venv .venv && . .venv/bin/activate && pip install -r requirements.txt",
    "backend:dev": "cd backend && . .venv/bin/activate && uvicorn app.main:app --reload --host 127.0.0.1 --port 8742",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.purplepatch.offline-ai-transcriber",
    "productName": "Purplepatch Offline AI Transcriber",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "backend/**/*",
      "!backend/.venv/**/*",
      "!backend/**/__pycache__/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!.venv/**",
          "!**/__pycache__/**"
        ]
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "python-runtime/mac/python",
          "to": "python"
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "python-runtime/win/python",
          "to": "python"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "vincentpalcon",
      "repo": "Purplepatch-Offline-AI-Transcriber",
      "releaseType": "release"
    }
  }
}
