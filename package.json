{
  "name": "purplepatch-offline-ai-transcriber",
  "version": "0.1.0",
  "description": "Purplepatch Offline AI Transcriber — professional offline transcription desktop app for macOS and Windows",
  "main": "out/main/index.js",
  "author": "Purplepatch",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "backend:setup": "cd backend && python3 -m venv .venv && . .venv/bin/activate && pip install -r requirements.txt",
    "backend:dev": "cd backend && . .venv/bin/activate && uvicorn app.main:app --reload --host 127.0.0.1 --port 8742"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.purplepatch.offline-ai-transcriber",
    "productName": "Purplepatch Offline AI Transcriber",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "backend/**/*",
      "!backend/.venv/**/*",
      "!backend/**/__pycache__/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*", "!.venv/**", "!**/__pycache__/**"]
      },
      {
        "from": "models",
        "to": "models"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}